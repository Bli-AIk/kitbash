# ===============================================
# 默认任务：debug 构建
# ===============================================
default:
    cargo build

# ===============================================
# 格式化
# ===============================================
fmt:
    cargo fmt --all

# ===============================================
# clippy
# ===============================================
clippy:
    cargo clippy --all-targets -- -W clippy::all

# ===============================================
# Tokei 行数检查
# ===============================================
tokei-check:
    @./tokei_check.sh 800 src/

alias line := tokei-check

# ===============================================
# check
# ===============================================
check:
    cargo check --all-targets

# ===============================================
# 综合检查
# ===============================================
full_check: clippy tokei-check
    echo "all checks completed"

# ===============================================
# clippy 自动修复
# ===============================================
fix:
    cargo clippy --fix --allow-dirty --allow-staged

# ===============================================
# release 构建
# ===============================================
release:
    cargo build --release

# ===============================================
# 运行
# ===============================================
run:
    cargo run

# ===============================================
# 测试
# ===============================================
test:
    cargo test

# ===============================================
# 清理
# ===============================================
clean:
    cargo clean

# ===============================================
# WASM 构建
# ===============================================
wasm-build:
    cargo build --target wasm32-unknown-unknown --release

# ===============================================
# WASM 开发服务器
# ===============================================
wasm-dev:
    ./start_dev.sh
